#!/bin/sh
# Auto-patch frontend/index.html build tag and cache-buster when commit message
# starts with a version number (e.g. "v7.1.5 - description").

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# Extract leading vX.Y or vX.Y.Z
VERSION=$(echo "$COMMIT_MSG" | grep -oE '^v[0-9]+\.[0-9]+(\.[0-9]+)?')

if [ -z "$VERSION" ]; then
  exit 0
fi

INDEX="frontend/index.html"

if [ ! -f "$INDEX" ]; then
  exit 0
fi

# Patch build-tag div
sed -i "s|<div id=\"build-tag\">[^<]*</div>|<div id=\"build-tag\">${VERSION}</div>|" "$INDEX"

# Patch app.js cache-buster (?v=...)
VER_NUM="${VERSION#v}"
sed -i "s|app\.js?v=[^\"]*|app.js?v=${VER_NUM}|" "$INDEX"

git add "$INDEX"
